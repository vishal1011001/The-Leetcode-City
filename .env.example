# LeetCode City - Environment Variables
# ─────────────────────────────────────────────────────────────
# This file is pre-filled with the PUBLIC read-only keys.
# Just copy it to .env.local and you're ready to develop!
#
#   cp .env.example .env.local
#   npm run dev
#
# Or run the automated setup:
#   npm run setup
# ─────────────────────────────────────────────────────────────

# ── App URL (auto-set, don't change) ────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ── Supabase (pre-filled with public read-only keys) ────────
# These are the same keys bundled in the production client JS.
# They are safe to share — all writes are protected by RLS.
NEXT_PUBLIC_SUPABASE_URL=https://ykqxkfazxsyantffjouf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlrcXhrZmF6eHN5YW50ZmZqb3VmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI4NDYyNTEsImV4cCI6MjA4ODQyMjI1MX0.-sdtrt-WcwEQx5GScueNv9jyx7KgAfG3EHWIZdtSLa4

# ── Service Role Key (LEAVE BLANK for frontend-only work) ───
# Only needed if you're working on server-side API routes.
# Without it, the app runs in "dev mode" (read-only, no auth).
# Ask @Ixotic27 for the key if you need it for your issue.
SUPABASE_SERVICE_ROLE_KEY=

# ── Arena hidden-test encryption ─────────────────────────────
# Required by the arena challenge API.
# Generate a strong value with: openssl rand -hex 32
# Keep this value private and configure it in the deployment environment.
ARENA_CRYPTO_KEY=

# ── GitHub Token (LEAVE BLANK for most work) ────────────────
# Only needed if you're working on the GitHub API integration.
# Generate one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# ── Upstash Redis (distributed rate limiting) ───────────────
# Required for production rate limiting across Vercel instances.
# Create a free database at: https://console.upstash.com
# Copy the REST URL and token from the database dashboard.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Optional Keys (only if working on these features) ───────
# Stripe (payment features)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Generative AI
GOOGLE_GENAI_API_KEY=

# NowPayments (crypto payments)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Resend (email notifications)
RESEND_API_KEY=

# AbacatePay (BRL payments)
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=

# Himetrica (analytics)
NEXT_PUBLIC_HIMETRICA_API_KEY=

# Cron jobs
CRON_SECRET=

#Rate Limit
RATE_LIMIT_PER_HOUR=

#Cache TTL (12-hour)
CACHE_TTL_HOURS=

# OpenWeatherMap API (Weather feature)
OPENWEATHER_API_KEY=

# ── Arena Crypto Key (REQUIRED for arena features) ───────────
# Used to encrypt/decrypt hidden test cases for arena challenges.
# Generate one with: openssl rand -hex 32
ARENA_CRYPTO_KEY=

# ── PartyKit (Multiplayer Presence & Chat) ────────────────────
# Defaults to localhost:1999 for local development.
# In production, set to your deployed PartyKit host (e.g., leetcode-city-multiplayer.your-user.partykit.dev)
NEXT_PUBLIC_PARTYKIT_HOST=localhost:1999


# ── E.Arcade Admin/Editor configuration ──────────────────────
# Comma-separated list of GitHub usernames permitted to edit maps/portals.
ADMIN_GITHUB_LOGINS=
# Secure random string/key for auth.
ARCADE_ADMIN_KEY=