{
  "name": "leetcode-city-pulse",
  "displayName": "LeetCode City: Pulse",
  "description": "Keep your city alive. When you code, your building glows and powers the signal. Privacy-first: you control what gets shared.",
  "version": "0.2.3",
  "publisher": "leetcode-city",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ixotic27/leetcode-city"
  },
  "homepage": "https://the-leetcode-city.vercel.app",
  "bugs": {
    "url": "https://github.com/Ixotic27/leetcode-city/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "icon.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "leetcode-city-arena",
          "title": "LeetCode City Arena",
          "icon": "resources/arena-icon.svg"
        }
      ]
    },
    "views": {
      "leetcode-city-arena": [
        {
          "type": "webview",
          "id": "leetcodecity.arenaView",
          "name": "Arena Challenges"
        }
      ]
    },
    "commands": [
      {
        "command": "leetcodecity.login",
        "title": "Pulse: Connect"
      },
      {
        "command": "leetcodecity.logout",
        "title": "Pulse: Disconnect"
      },
      {
        "command": "leetcodecity.togglePause",
        "title": "Pulse: Toggle"
      },
      {
        "command": "leetcodecity.showDashboard",
        "title": "Pulse: Open City"
      }
    ],
    "configuration": {
      "title": "Leetcode City",
      "properties": {
        "leetcodecity.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable activity tracking"
        },
        "leetcodecity.apiUrl": {
          "type": "string",
          "default": "https://the-leetcode-city.vercel.app",
          "description": "LeetCode City API URL (changing this sends your API key to a different server)",
          "scope": "application"
        },
        "leetcodecity.privacy.shareLanguage": {
          "type": "boolean",
          "default": true,
          "description": "Share the programming language you're using (shown publicly on your building)"
        },
        "leetcodecity.privacy.shareProject": {
          "type": "boolean",
          "default": true,
          "description": "Send project name for your personal analytics (never shown publicly to other users)"
        },
        "leetcodecity.privacy.excludeProjects": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Project names to never track at all (e.g. secret-project, client-work)"
        },
        "leetcodecity.idleTimeout": {
          "type": "number",
          "default": 300,
          "minimum": 60,
          "maximum": 3600,
          "description": "Seconds of inactivity before marking as idle"
        },
        "leetcodecity.cryptoKey": {
          "type": "string",
          "default": "",
          "description": "Arena encryption key for decrypting hidden test cases (at least 32 characters). Generate one with: openssl rand -hex 32",
          "scope": "application"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}